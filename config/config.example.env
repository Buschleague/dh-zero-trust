# Duo Admin API Credentials
# Get these from: Duo Admin Panel → Applications → Admin API
DUO_IKEY=DIXXXXXXXXXXXXXXXXXX
DUO_SKEY=YourSecretKeyHere
DUO_HOST=api-XXXXXXXX.duosecurity.com

# Cisco Security Cloud Control / Secure Access (Phase 1)
SCC_KEY_ID=your_key_id_here
SCC_ACCESS_TOKEN=your_access_token_here
SCC_REFRESH_TOKEN=your_refresh_token_here

# Meraki API (Phase 2 — may use SCC token instead)
# MERAKI_API_KEY=your_meraki_api_key_here
# MERAKI_ORG_ID=your_org_id_here
